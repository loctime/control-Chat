rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function validReplyFields(data) {
      // Las tres propiedades de reply deben estar todas presentes o todas
      // ausentes; cuando estan presentes deben ser strings (replyToId no vacio).
      let replyKeys = ['replyToId', 'replyToText', 'replyToAuthor'];
      return !data.keys().hasAny(replyKeys) || (
        data.keys().hasAll(replyKeys)
        && data.replyToId is string && data.replyToId.size() > 0
        && data.replyToText is string
        && data.replyToAuthor is string
      );
    }

    function validCreateMessage(data) {
      return data.keys().hasOnly([
          'type',
          'text',
          'createdAt',
          'device',
          'starred',
          'author',
          'replyToId',
          'replyToText',
          'replyToAuthor'
        ])
        && data.type in ['text', 'link']
        && data.device in ['mobile', 'desktop']
        && data.starred is bool
        && data.createdAt is timestamp
        && data.text is string
        && data.text.size() > 0
        && data.text.size() <= 2000
        && (data.type != 'link' || data.text.matches('^https?://.+'))
        && data.author is string
        && data.author.size() > 0
        && data.author.size() <= 200
        && validReplyFields(data);
    }

    match /apps/control-chat/users/{userId} {
      allow read: if isOwner(userId);
      allow create, update: if isOwner(userId);
      allow delete: if false;

      match /messages/{messageId} {
        allow read: if isOwner(userId);

        allow create: if isOwner(userId)
          && validCreateMessage(request.resource.data);

        allow update: if isOwner(userId)
          && request.resource.data.diff(resource.data).changedKeys().hasOnly(['starred'])
          && request.resource.data.starred is bool;

        allow delete: if isOwner(userId);
      }
    }
  }
}
